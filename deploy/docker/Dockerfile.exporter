FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /exporter ./cmd/exporter

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
WORKDIR /
COPY --from=build /exporter /exporter
USER nobody
EXPOSE 9100
ENV EXPORTER_LISTEN=:9100
ENTRYPOINT ["/exporter"]
